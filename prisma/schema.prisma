generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  member
  admin
}

enum Channel {
  sms
  email
  google_chat
}

enum TaskStatus {
  open
  in_progress
  done
  overdue
}

enum MessageDirection {
  inbound
  outbound
}

enum WorkspaceRole {
  admin
  member
}

model User {
  id               String         @id @default(uuid())
  name             String
  role             Role           @default(member)
  preferredChannel Channel
  quietHoursStart  String?        // e.g. "21:00"
  quietHoursEnd    String?        // e.g. "08:00"
  timezone         String         @default("America/New_York")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  addresses        UserAddress[]
  assignedTasks    Task[]         @relation("assignee")
  createdTasks     Task[]         @relation("creator")
  messages         Message[]
  memberships      WorkspaceMember[]
  magicLinks       MagicLink[]
  createdInvites   InviteLink[]   @relation("inviteCreator")

  @@map("users")
}

model UserAddress {
  id      String  @id @default(uuid())
  userId  String
  channel Channel
  address String  @unique

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_addresses")
}

model Task {
  id          String     @id @default(uuid())
  title       String
  description String?
  status      TaskStatus @default(open)
  dueDate     DateTime?
  assigneeId  String
  creatorId   String
  workspaceId String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  assignee  User       @relation("assignee", fields: [assigneeId], references: [id])
  creator   User       @relation("creator", fields: [creatorId], references: [id])
  workspace Workspace? @relation(fields: [workspaceId], references: [id])
  messages  Message[]

  @@map("tasks")
}

model Message {
  id           String           @id @default(uuid())
  taskId       String?
  userId       String
  channel      Channel
  direction    MessageDirection
  rawText      String
  parsedIntent String?          // JSON string of parsed intent
  createdAt    DateTime         @default(now())

  task Task? @relation(fields: [taskId], references: [id])
  user User  @relation(fields: [userId], references: [id])

  @@map("messages")
}

model Workspace {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members     WorkspaceMember[]
  tasks       Task[]
  inviteLinks InviteLink[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String        @id @default(uuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(member)
  joinedAt    DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model InviteLink {
  id          String    @id @default(uuid())
  workspaceId String
  token       String    @unique
  createdById String
  expiresAt   DateTime?
  maxUses     Int?
  useCount    Int       @default(0)
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User      @relation("inviteCreator", fields: [createdById], references: [id])

  @@map("invite_links")
}

model MagicLink {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("magic_links")
}
