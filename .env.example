# Database
DATABASE_URL=postgresql://user:password@localhost:5432/relay

# Redis
REDIS_URL=redis://localhost:6379

# Telnyx (SMS)
TELNYX_API_KEY=your_telnyx_api_key
TELNYX_PHONE_NUMBER=+1234567890
TELNYX_PUBLIC_KEY=your_telnyx_public_key

# Resend (Email)
RESEND_API_KEY=your_resend_api_key
RELAY_FROM_EMAIL=relay@yourdomain.com

# Google Chat
GOOGLE_CHAT_SERVICE_ACCOUNT_KEY=path/to/service-account.json
GOOGLE_CHAT_PROJECT_ID=your_project_id

# Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key

# App
PORT=3000
NODE_ENV=development
