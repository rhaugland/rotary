# Database
DATABASE_URL=postgresql://user:password@localhost:5432/relay

# Redis
REDIS_URL=redis://localhost:6379

# Twilio (SMS)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# SendGrid (Email)
SENDGRID_API_KEY=your_sendgrid_api_key
RELAY_EMAIL_DOMAIN=relay.yourdomain.com
RELAY_FROM_EMAIL=relay@yourdomain.com

# Google Chat
GOOGLE_CHAT_SERVICE_ACCOUNT_KEY=path/to/service-account.json
GOOGLE_CHAT_PROJECT_ID=your_project_id

# Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key

# App
PORT=3000
NODE_ENV=development
